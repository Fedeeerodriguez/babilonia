# ============================================================
#  ENTORNO DEMO — backend (NO usar en producción real)
#  Copiar estas variables en el servicio "babilonia-demo-backend" de EasyPanel
# ============================================================

# --- App ---
SECRET_KEY=GENERAR-UNO-NUEVO-PARA-DEMO   # ej: openssl rand -hex 32
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PORT=8020

# CORS: dominio del frontend demo (ajustar al que uses en Cloudflare)
CORS_ORIGINS=https://demo.babilonia.tudominio.com

# --- Base de datos DEMO (separada de producción) ---
# Opción A (recomendada): Postgres nuevo dentro de EasyPanel
#   DATABASE_URL=postgresql://postgres:PASS@babilonia-demo-db:5432/postgres
# Opción B: proyecto Supabase nuevo solo para demo
#   DATABASE_URL=postgresql://postgres:PASS@db.PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:CAMBIAR@babilonia-demo-db:5432/postgres

# --- Auto-seed demo: carga la cartera ficticia al arrancar ---
DEMO_SEED=1
# DEMO_RESET=1   # descomentar UNA vez si querés borrar y recrear los datos demo

# --- Notion: VACÍO a propósito en demo (pantallas de pólizas quedan vacías, sin romper) ---
NOTION_TOKEN=

# --- OpenAI: opcional. Solo si querés que el AgentChat demo responda de verdad ---
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini

# --- Supabase Storage: no necesario para el demo ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=
