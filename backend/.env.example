# --- App ---
SECRET_KEY=change-me-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
PORT=8020

# --- Supabase Postgres (mismo cluster donde vive `messages` y `documents`) ---
# Pegá el connection string de Supabase > Project Settings > Database > Connection string (URI, pooler 6543 recomendado para serverless)
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# --- Supabase API (solo si usás Storage para PDFs originales) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# --- OpenAI (embeddings + agente interno) ---
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini

