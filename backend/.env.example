# --- App ---
SECRET_KEY=change-me-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
PORT=8020
# En producción poné RELOAD=0 (evita el auto-reloader de uvicorn dentro del contenedor).
RELOAD=0

# --- Supabase Postgres (mismo cluster donde vive `messages` y `documents`) ---
# Pegá el connection string de Supabase > Project Settings > Database > Connection string (URI, pooler 6543 recomendado para serverless)
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# --- Supabase API (solo si usás Storage para PDFs originales) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# --- OpenAI (embeddings + agente interno) ---
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini

# --- Vector store de documents (n8n / LangChain) ---
# Si la tabla `documents` vive en OTRO Postgres que el de `messages`, seteá esto.
# Si está en el mismo, dejalo vacío (usa DATABASE_URL).
DOCUMENTS_DATABASE_URL=
DOCUMENTS_TABLE=documents

# --- Tomi: auth interna entre n8n y el backend ---
# MISMO valor en el backend y en la env var TOMI_INTERNAL_KEY de n8n.
# Generá uno: openssl rand -hex 32
TOMI_INTERNAL_KEY=

# --- Caché de Notion (opcional) ---
TOMI_CACHE_TTL=300
TOMI_CACHE_MAX_SIZE=500

# --- Notion (sub-agente bases_datos) ---
# Token de la integración Notion (https://www.notion.so/my-integrations) — la integración
# debe estar compartida con cada database de abajo.
NOTION_TOKEN=

# IDs de databases (el ID de 32 chars de la URL de cada DB). Solo hace falta cargar las que uses.
NOTION_DB_ASESORES=
NOTION_DB_ESTUDIANTES=
NOTION_DB_CLIENTES=
NOTION_DB_EMISIONES=
NOTION_DB_COBRANZAS=
NOTION_DB_TICKETS_ALLIANZ=
NOTION_DB_TICKETS_BABILONIA=
NOTION_DB_EVENTOS_CALENDLY=
NOTION_DB_RENOVACIONES=
NOTION_DB_SINIESTROS=
NOTION_DB_COMISIONES_AGENTES=
NOTION_DB_BONOS_AGENTES=
NOTION_DB_BONOS_PROMOTORIA=
NOTION_DB_PUNTOS_CONVENCION=
NOTION_DB_PRODUCTOS=
NOTION_DB_CLIENTES_PPR=
NOTION_DB_MIGRACION_CARTERA=
NOTION_DB_PORTAFOLIOS=
# Sub-DBs de clientes por producto (opcionales)
NOTION_DB_CLIENTES_AUTO=
NOTION_DB_CLIENTES_PATRIMONIAL=
NOTION_DB_CLIENTES_EDUCACIONAL=
NOTION_DB_CLIENTES_GMM=
NOTION_DB_CLIENTES_RENTAS_PRIVADAS=
NOTION_DB_CLIENTES_RESIDENCIAL=
NOTION_DB_CLIENTES_PROTECCION=
NOTION_DB_CLIENTES_ELITE=
NOTION_DB_MIGRACION_CLIENTES=

